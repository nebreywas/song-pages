{
  "name": "song-pages",
  "version": "1.0.2",
  "description": "Song Pages - decentralized music publishing desktop app (PoC)",
  "main": "electron/main.js",
  "author": "Ben Sawyer",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "predev": "node scripts/free-dev-port.mjs 5173",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && node scripts/launch-electron.mjs\"",
    "build:compiler": "node scripts/build-compiler.mjs",
    "generate:butterchurn-catalog": "node scripts/generate-butterchurn-catalog.mjs",
    "generate:kudo-catalog": "node scripts/generate-kudo-asset-catalog.mjs",
    "build": "npm run build:compiler && npm run generate:butterchurn-catalog && npm run generate:kudo-catalog && vite build",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:linux": "npm run build && electron-builder --linux",
    "release:mac": "node scripts/release.mjs --mac",
    "release:win": "node scripts/release.mjs --win",
    "release:all": "node scripts/release.mjs --all",
    "icons:win": "node scripts/build-win-icon.mjs",
    "test": "node --import tsx --test shared/**/*.test.ts compiler/*.test.ts src/audio/**/*.test.ts src/playback/**/*.test.ts",
    "test:db": "node scripts/run-electron-db-tests.mjs",
    "backup:db": "node scripts/backup-database.mjs",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@melloware/coloris": "^0.25.0",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^11.8.1",
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "dompurify": "^3.4.11",
    "double-metaphone": "^2.0.1",
    "hls.js": "^1.6.16",
    "html-to-image": "^1.11.13",
    "jsmediatags": "^3.9.7",
    "marked": "^18.0.5",
    "meyda": "^5.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.17.5",
    "wavesurfer.js": "^7.12.10"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.25.12",
    "to-ico": "^1.1.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.4",
    "vite": "^6.2.0",
    "wait-on": "^8.0.2"
  }
}
